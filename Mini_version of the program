import sympy as sp

x = sp.symbols('x')

expr = input("Enter function in x: ")
f = sp.sympify(expr)

f1 = sp.diff(f, x)
f2 = sp.diff(f1, x)

critical = sp.solve(f1, x)
inflection = sp.solve(f2, x)

print("\nFunction:", f)
print("f'(x):", f1)
print("f''(x):", f2)
print("Critical Points:", critical)
print("Inflection Points:", inflection)

# Simple increasing/decreasing test
for c in critical:
    test = f1.subs(x, c - 1)
    if test > 0:
        print(f"Left of {c}: Increasing")
    else:
        print(f"Left of {c}: Decreasing")
